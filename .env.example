# .env.example
# =============
# Copia este archivo como .env y ajusta los valores según tu entorno.
# El archivo .env NUNCA debe commitearse al repositorio.
#
# Uso en Python:
#   from dotenv import load_dotenv
#   load_dotenv()

# ── Nivel de logging ──────────────────────────────────────────────
# Opciones: DEBUG | INFO | WARNING | ERROR
AMD_LOG_LEVEL=INFO

# ── Mostrar gráficas en pantalla ──────────────────────────────────
# 0 = solo guardar en disco (modo producción / CI)
# 1 = mostrar ventanas interactivas (modo notebook / desarrollo)
AMD_SHOW_PLOTS=0

# ── Ticker y rango temporal (opcional, sobreescribe config.py) ────
# AMD_TICKER=AMD
# AMD_START=2020-01-01
# AMD_END=2024-12-31
